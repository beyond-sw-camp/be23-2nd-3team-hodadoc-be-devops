        <mxCell id="f-sb" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="&lt;b&gt;Server B&lt;/b&gt;&#xa;onMessage()&#xa;로컬 emitter 확인" vertex="1">
