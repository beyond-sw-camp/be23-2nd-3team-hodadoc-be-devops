        <mxCell id="f-offline" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=2;" value="👤 오프라인 사용자&#xa;→ 재접속 시 RabbitMQ flush" vertex="1">
