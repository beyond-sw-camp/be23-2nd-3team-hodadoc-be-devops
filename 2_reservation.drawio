<mxfile host="app.diagrams.net" version="29.6.1">
  <diagram name="예약" id="reservation-flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== 타이틀 ===== -->
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#333;" value="2. 예약 (Reservation)" vertex="1">
          <mxGeometry x="450" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- ========================================== -->
        <!-- 환자: 예약 생성 흐름                         -->
        <!-- ========================================== -->
        <mxCell id="patient-section" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#4A86C8;strokeWidth=2;dashed=1;fontSize=14;fontStyle=1;fontColor=#4A86C8;verticalAlign=top;spacingTop=5;" value="환자: 예약 생성 흐름" vertex="1">
          <mxGeometry x="30" y="80" width="1540" height="380" as="geometry" />
        </mxCell>

        <!-- Step 1: profileGuard -->
        <mxCell id="p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" value="① profileGuard&#xa;검증" vertex="1">
          <mxGeometry x="50" y="130" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p1-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#6c8ebf;align=center;" value="JWT 토큰 검증&#xa;+ 이름/전화번호 확인&#xa;미완성 → 마이페이지 이동" vertex="1">
          <mxGeometry x="35" y="180" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- Step 2: 병원/의사/날짜 선택 -->
        <mxCell id="p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" value="② 의사 선택&#xa;+ 날짜 선택" vertex="1">
          <mxGeometry x="230" y="130" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#6c8ebf;align=center;" value="병원 상세 페이지에서&#xa;의사 목록 → 캘린더" vertex="1">
          <mxGeometry x="215" y="180" width="150" height="30" as="geometry" />
        </mxCell>

        <!-- Step 3: 가용 시간대 조회 -->
        <mxCell id="p3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" value="③ 가용 시간대 조회" vertex="1">
          <mxGeometry x="410" y="130" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p3-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="GET /reservation/slots&#xa;?doctorId &amp; date" vertex="1">
          <mxGeometry x="410" y="180" width="140" height="25" as="geometry" />
        </mxCell>

        <!-- 시간대 생성 로직 상세 -->
        <mxCell id="p3-detail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;fontSize=9;align=left;spacingLeft=10;" value="&lt;b&gt;슬롯 생성 로직 (Backend)&lt;/b&gt;&#xa;&#xa;1. DoctorSchedule 조회 (요일별 근무시간)&#xa;2. 근무시작~종료를 consultationInterval로 분할&#xa;3. 점심시간 슬롯 제외&#xa;4. DoctorOffDay (의사 휴무) 체크 → 전체 비활성&#xa;5. HospitalHoliday (병원 휴무) 체크 → 전체 비활성&#xa;6. PublicHoliday (공휴일) 체크 → 전체 비활성&#xa;7. 기존 예약/블록된 슬롯 → 개별 비활성" vertex="1">
          <mxGeometry x="310" y="220" width="310" height="150" as="geometry" />
        </mxCell>

        <!-- DB -->
        <mxCell id="p3-db" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=6;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" value="MariaDB&#xa;DoctorSchedule&#xa;DoctorOffDay&#xa;HospitalHoliday" vertex="1">
          <mxGeometry x="310" y="385" width="120" height="55" as="geometry" />
        </mxCell>

        <!-- Step 4: 예약 요청 -->
        <mxCell id="p4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" value="④ 예약 요청" vertex="1">
          <mxGeometry x="680" y="130" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p4-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="POST /reservation/patient&#xa;{ doctorId, date, time, symptoms }" vertex="1">
          <mxGeometry x="655" y="180" width="180" height="25" as="geometry" />
        </mxCell>

        <!-- Redis 분산 락 -->
        <mxCell id="p4-lock" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" value="Redis 분산 락&#xa;tryLock(슬롯)" vertex="1">
          <mxGeometry x="680" y="220" width="130" height="40" as="geometry" />
        </mxCell>

        <!-- 검증 -->
        <mxCell id="p4-validate" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;fontSize=9;" value="검증: 병원 삭제여부&#xa;+ 휴무일 + 중복예약" vertex="1">
          <mxGeometry x="680" y="270" width="130" height="35" as="geometry" />
        </mxCell>

        <!-- DB 저장 -->
        <mxCell id="p4-db" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=6;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" value="MariaDB&#xa;ReservationPatient&#xa;저장" vertex="1">
          <mxGeometry x="680" y="320" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Step 5: 승인 모드 분기 -->
        <mxCell id="p5" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;fontStyle=1;fontColor=#E65100;" value="⑤ 승인 모드?" vertex="1">
          <mxGeometry x="890" y="120" width="130" height="70" as="geometry" />
        </mxCell>

        <!-- AUTO 경로 -->
        <mxCell id="p5-auto" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" value="AUTO&#xa;status = APPROVED" vertex="1">
          <mxGeometry x="1080" y="100" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p5-auto-sse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#CC6600;fontSize=9;fontColor=#CC6600;" value="SSE → 병원: 자동승인 알림&#xa;SMS → 환자: 예약 확정" vertex="1">
          <mxGeometry x="1280" y="95" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- MANUAL 경로 -->
        <mxCell id="p5-manual" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" value="MANUAL&#xa;status = WAITING" vertex="1">
          <mxGeometry x="1080" y="170" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p5-manual-sse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#CC6600;fontSize=9;fontColor=#CC6600;" value="SSE → 병원: 새 예약 대기 알림&#xa;(환자는 대기 상태)" vertex="1">
          <mxGeometry x="1280" y="165" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- 환자 흐름 화살표 -->
        <mxCell id="pa1" edge="1" parent="1" source="p1" target="p2" style="rounded=1;orthogonalLoop=1;strokeColor=#333;strokeWidth=2;">
