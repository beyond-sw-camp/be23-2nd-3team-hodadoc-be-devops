        </mxCell>
        <mxCell id="pa5a-label" connectable="0" parent="pa5a" style="edgeLabel;html=1;fontSize=9;fontColor=#82b366;fontStyle=1;" value="AUTO" vertex="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="-10" as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="pa5m" edge="1" parent="1" source="p5" target="p5-manual" style="rounded=1;orthogonalLoop=1;strokeColor=#E65100;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pa5m-label" connectable="0" parent="pa5m" style="edgeLabel;html=1;fontSize=9;fontColor=#E65100;fontStyle=1;" value="MANUAL" vertex="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="10" as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="pa5as" edge="1" parent="1" source="p5-auto" target="p5-auto-sse" style="rounded=1;orthogonalLoop=1;strokeColor=#CC6600;strokeWidth=1;">
