        </mxCell>

        <!-- ========================================== -->
        <!-- 병원관리자: 예약 관리 흐름                     -->
        <!-- ========================================== -->
        <mxCell id="hospital-section" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;strokeWidth=2;dashed=1;fontSize=14;fontStyle=1;fontColor=#82b366;verticalAlign=top;spacingTop=5;" value="병원관리자: 예약 관리 흐름" vertex="1">
          <mxGeometry x="30" y="480" width="1540" height="300" as="geometry" />
        </mxCell>

        <!-- 예약 목록 조회 -->
        <mxCell id="h1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" value="① 예약 목록 조회" vertex="1">
          <mxGeometry x="50" y="530" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h1-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="GET /reservation/hospital&#xa;GET /reservation/list (주간 뷰)" vertex="1">
          <mxGeometry x="30" y="580" width="170" height="25" as="geometry" />
        </mxCell>

        <!-- 승인 -->
        <mxCell id="h2a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" value="② 승인" vertex="1">
          <mxGeometry x="280" y="520" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h2a-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="PATCH /{id}/approve&#xa;WAITING → APPROVED" vertex="1">
          <mxGeometry x="265" y="560" width="150" height="25" as="geometry" />
        </mxCell>
        <mxCell id="h2a-sse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#CC6600;fontSize=9;fontColor=#CC6600;" value="SSE → 환자: 예약 승인됨&#xa;SMS → 환자: 예약 확정" vertex="1">
          <mxGeometry x="450" y="515" width="170" height="40" as="geometry" />
        </mxCell>

        <!-- 거절 -->
        <mxCell id="h2b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" value="② 거절" vertex="1">
          <mxGeometry x="280" y="600" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h2b-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#b85450;align=center;" value="PATCH /{id}/reject&#xa;WAITING → REJECTED" vertex="1">
          <mxGeometry x="265" y="640" width="150" height="25" as="geometry" />
        </mxCell>
        <mxCell id="h2b-sse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#CC6600;fontSize=9;fontColor=#CC6600;" value="SSE → 환자: 예약 거절됨&#xa;SMS → 환자: 예약 거절" vertex="1">
          <mxGeometry x="450" y="595" width="170" height="40" as="geometry" />
        </mxCell>

        <!-- 취소 -->
        <mxCell id="h3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" value="③ 예약 취소" vertex="1">
          <mxGeometry x="280" y="680" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h3-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#b85450;align=center;" value="PATCH /{id}/cancel&#xa;→ CANCELLED" vertex="1">
          <mxGeometry x="265" y="720" width="150" height="25" as="geometry" />
        </mxCell>
        <mxCell id="h3-sse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#CC6600;fontSize=9;fontColor=#CC6600;" value="SSE → 환자: 예약 취소됨&#xa;SMS → 환자: 예약 취소" vertex="1">
          <mxGeometry x="450" y="675" width="170" height="40" as="geometry" />
        </mxCell>

        <!-- 슬롯 블록 -->
        <mxCell id="h4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" value="④ 슬롯 블록" vertex="1">
          <mxGeometry x="700" y="530" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h4-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="POST /reservation/hospital/block&#xa;status=BLOCKED, patient=null&#xa;환자가 해당 시간 예약 불가" vertex="1">
          <mxGeometry x="680" y="580" width="170" height="40" as="geometry" />
        </mxCell>

        <!-- 슬롯 블록 해제 -->
        <mxCell id="h5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" value="⑤ 블록 해제" vertex="1">
          <mxGeometry x="700" y="640" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h5-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="DELETE /reservation/hospital/block/{id}&#xa;블록 삭제 → 슬롯 재개" vertex="1">
          <mxGeometry x="680" y="690" width="170" height="25" as="geometry" />
        </mxCell>

        <!-- 예약 완료 처리 -->
        <mxCell id="h6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" value="⑥ 진료 완료" vertex="1">
          <mxGeometry x="900" y="530" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h6-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="PATCH /{id}/complete&#xa;APPROVED → COMPLETED&#xa;(리뷰 작성 가능)" vertex="1">
          <mxGeometry x="880" y="580" width="170" height="40" as="geometry" />
        </mxCell>

        <!-- 병원 관리 화살표 -->
        <mxCell id="ha1a" edge="1" parent="1" source="h1" target="h2a" style="rounded=1;orthogonalLoop=1;strokeColor=#82b366;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ha1a-label" connectable="0" parent="ha1a" style="edgeLabel;html=1;fontSize=8;fontColor=#82b366;" value="MANUAL 모드" vertex="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="-10" as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="ha1b" edge="1" parent="1" source="h1" target="h2b" style="rounded=1;orthogonalLoop=1;strokeColor=#b85450;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ha1c" edge="1" parent="1" source="h1" target="h3" style="rounded=1;orthogonalLoop=1;strokeColor=#b85450;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ha2as" edge="1" parent="1" source="h2a" target="h2a-sse" style="rounded=1;orthogonalLoop=1;strokeColor=#CC6600;strokeWidth=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ha2bs" edge="1" parent="1" source="h2b" target="h2b-sse" style="rounded=1;orthogonalLoop=1;strokeColor=#CC6600;strokeWidth=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ha3s" edge="1" parent="1" source="h3" target="h3-sse" style="rounded=1;orthogonalLoop=1;strokeColor=#CC6600;strokeWidth=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========================================== -->
        <!-- 동시성 제어 & 알림 요약                       -->
        <!-- ========================================== -->
        <mxCell id="bottom-section" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;strokeWidth=2;dashed=1;fontSize=14;fontStyle=1;fontColor=#9673a6;verticalAlign=top;spacingTop=5;" value="동시성 제어 &amp; SSE 알림 요약" vertex="1">
          <mxGeometry x="30" y="800" width="1540" height="190" as="geometry" />
        </mxCell>

        <!-- 동시성 제어 3중 방어 -->
        <mxCell id="lock-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=15;" value="&lt;b&gt;동시성 제어 (3중 방어)&lt;/b&gt;&#xa;&#xa;1차: Redis 분산 락 (tryLock)&#xa;  → 같은 슬롯에 동시 요청 시 하나만 통과&#xa;  → finally 블록에서 반드시 unlock&#xa;&#xa;2차: 서비스 레벨 중복 체크&#xa;  → 해당 슬롯에 활성 예약 존재 여부 조회&#xa;&#xa;3차: DB unique constraint&#xa;  → (doctor, date, time) 유니크 제약" vertex="1">
          <mxGeometry x="50" y="840" width="320" height="130" as="geometry" />
        </mxCell>

        <!-- SSE 알림 종류 -->
        <mxCell id="sse-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#CC6600;fontSize=11;align=left;spacingLeft=15;fontColor=#333;" value="&lt;b&gt;SSE 알림 종류&lt;/b&gt;&#xa;&#xa;RESERVATION_AUTO_APPROVED → 병원 (자동승인됨)&#xa;RESERVATION_WAITING → 병원 (새 예약 대기)&#xa;RESERVATION_APPROVED → 환자 (승인됨)&#xa;RESERVATION_REJECTED → 환자 (거절됨)&#xa;RESERVATION_CANCELLED → 환자 (취소됨)&#xa;&#xa;+ 승인/거절/취소 시 SMS 발송 (Solapi)" vertex="1">
          <mxGeometry x="420" y="840" width="340" height="130" as="geometry" />
        </mxCell>

        <!-- 예약 상태 전이 -->
        <mxCell id="status-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#4A86C8;fontSize=11;align=left;spacingLeft=15;fontColor=#333;" value="&lt;b&gt;예약 상태 전이 (Status)&lt;/b&gt;&#xa;&#xa;AUTO 모드:&#xa;  → APPROVED → COMPLETED&#xa;  → APPROVED → CANCELLED&#xa;&#xa;MANUAL 모드:&#xa;  → WAITING → APPROVED → COMPLETED&#xa;  → WAITING → REJECTED&#xa;  → WAITING → CANCELLED&#xa;&#xa;BLOCKED (관리자 슬롯 차단, 환자 없음)" vertex="1">
          <mxGeometry x="810" y="840" width="300" height="130" as="geometry" />
        </mxCell>

        <!-- 범례 -->
        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCC;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;" value="&lt;b&gt;범례&lt;/b&gt;&#xa;🔵 파란색 = 프론트엔드 (Vue)&#xa;🟢 초록색 = 백엔드 (Spring Boot)&#xa;🟡 노란색 = Redis (분산 락)&#xa;🟣 보라색 = MariaDB&#xa;🟠 주황색 = SSE 알림 / SMS&#xa;◇ 다이아몬드 = 분기 (AUTO/MANUAL)" vertex="1">
          <mxGeometry x="1160" y="840" width="230" height="130" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
