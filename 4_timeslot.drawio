        </mxCell>

        <!-- 핵심 포인트 -->
        <mxCell id="key-points" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F8E9;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=15;" value="&lt;b&gt;핵심 포인트&lt;/b&gt;&#xa;&#xa;• 슬롯은 사전 생성하지 않음 → 조회 시 실시간 계산&#xa;• consultationInterval이 슬롯 크기를 결정&#xa;  (15분, 20분, 30분 등 병원별 설정)&#xa;• 휴무 체크 우선순위:&#xa;  isDayOff → DoctorOffDay → HospitalHoliday&#xa;  → PublicHoliday → 슬롯별 예약/블록 체크&#xa;• 블록: 관리자가 특정 슬롯을 수동 차단" vertex="1">
          <mxGeometry x="470" y="700" width="380" height="130" as="geometry" />
        </mxCell>

        <!-- 범례 -->
        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCC;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;" value="&lt;b&gt;범례&lt;/b&gt;&#xa;🔵 파란색 = 프론트엔드 (Vue)&#xa;🟢 초록색 = 백엔드 (Spring Boot)&#xa;🟣 보라색 = MariaDB&#xa;🔴 빨간색 = 외부 API (공공데이터포털)&#xa;◇ 다이아몬드 = 조건 분기&#xa;&#xa;&lt;b&gt;관련 API&lt;/b&gt;&#xa;PUT /doctor/{id}/schedule&#xa;POST /doctor/{id}/off-days/batch&#xa;GET /reservation/slots" vertex="1">
          <mxGeometry x="890" y="700" width="250" height="130" as="geometry" />
        </mxCell>

        <!-- 슬롯 예시 시각화 -->
        <mxCell id="slot-visual" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;fontColor=#333;" value="&lt;b&gt;슬롯 결과 예시 (30분 간격)&lt;/b&gt;&#xa;&#xa;09:00 ✅ available&#xa;09:30 ✅ available&#xa;10:00 ❌ 예약됨&#xa;10:30 🚫 BLOCKED&#xa;11:00 ✅ available&#xa;11:30 ✅ available&#xa;12:00 ~ 12:30  (점심시간 제외)&#xa;13:00 ✅ available ..." vertex="1">
          <mxGeometry x="1180" y="700" width="230" height="130" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
