        <mxCell id="g-hospital" value="&lt;b&gt;Hospital&lt;/b&gt;&#xa;id, name, phone, introduction&#xa;status (PENDING/APPROVED/REJECTED/DELETED)&#xa;reservationApprovalMode (AUTO/MANUAL)&#xa;checkinClosedDate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
