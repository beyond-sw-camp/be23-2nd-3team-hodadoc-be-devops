        <!-- 지도 기능 -->
        <mxCell id="d-features" value="&lt;b&gt;지도 기능&lt;/b&gt;&#xa;• 마커 표시 (초록=기본, 주황=선택)&#xa;• 반경 필터 (1km, 2km, 5km)&#xa;• 「이 지역 재검색」 버튼&#xa;• GPS 버튼 (내 위치 이동)&#xa;• 하단 플로팅 카드 캐러셀&#xa;• 주소 → 좌표 변환 (Geocoding 폴백)" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="260" y="880" width="240" height="110" as="geometry"/>
        </mxCell>

        <!-- Nearby API -->
        <mxCell id="d-nearby" value="GET /hospital/nearby&#xa;?userLat=&amp;userLng=&amp;radius=5&#xa;→ 반경 내 병원 목록" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="960" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- 거리 계산 -->
