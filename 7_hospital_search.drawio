        </mxCell>

        <!-- Step 2: 검색 조건 입력 -->
        <mxCell id="a2" value="② 검색 조건 입력&#xa;(HospitalList.vue)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="20" y="250" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- 필터 상세 -->
        <mxCell id="a-filters" value="&lt;b&gt;검색 필터 항목&lt;/b&gt;&#xa;• 키워드 (병원명, 주소, 진료과)&#xa;• 지역 선택 (시도 → 시군구 → 읍면동)&#xa;• 진료과 선택 (다중 선택 모달)&#xa;• 동적 필터: 시간, 휴일, 시설, 서비스&#xa;• 진료중 토글 (isCurrentlyOpen)" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="260" y="170" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- Step 3: API 호출 -->
        <mxCell id="a3" value="③ GET /hospital/list&#xa;HospitalSearchDto + Pageable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="20" y="320" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- Step 4: 필수 파라미터 검증 -->
        <mxCell id="a4" value="userLat, userLng&#xa;필수?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="390" width="110" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="a4-no" value="400 Bad Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="240" y="405" width="120" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 5: Native SQL -->
        <mxCell id="a5" value="④ Native SQL 쿼리 실행&#xa;(HospitalRepository)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="490" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- SQL 쿼리 내용 -->
        <mxCell id="a5-detail" value="&lt;b&gt;쿼리 로직&lt;/b&gt;&#xa;• status = APPROVED 만 조회&#xa;• 이름/주소/진료과 LIKE 검색&#xa;• 지역 필터 (sido, sigungu, emdName)&#xa;• 필터 존재 확인 (LEFT JOIN + EXISTS)&#xa;• 운영시간 체크 (요일 + 시간 + 점심시간)&#xa;• 휴무일/공휴일 제외&#xa;• ST_Distance_Sphere() 거리 계산" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="270" y="480" width="260" height="130" as="geometry"/>
        </mxCell>

        <!-- Step 6: 정렬 -->
        <mxCell id="a6" value="⑤ 3단계 정렬" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="560" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="a6-detail" value="1순위: 이름 관련도 (정확일치 &gt; 접두사 &gt; 기타)&#xa;2순위: 진료중 여부 (진료중 우선)&#xa;3순위: 거리순 (ST_Distance_Sphere ASC)" style="text;html=1;fontSize=10;align=left;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="30" y="600" width="300" height="50" as="geometry"/>
        </mxCell>

        <!-- Step 7: 결과 -->
        <mxCell id="a7" value="⑥ Page&lt;HospitalListDto&gt; 반환&#xa;→ 카드 목록 렌더링" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="670" width="200" height="40" as="geometry"/>
