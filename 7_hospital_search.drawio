        </mxCell>
        <mxCell id="g-image" value="&lt;b&gt;HospitalImage&lt;/b&gt;&#xa;imageUrl (S3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="470" y="1545" width="130" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="g-dept" value="&lt;b&gt;HospitalDepartment&lt;/b&gt;&#xa;→ Department (진료과)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1490" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="g-filter" value="&lt;b&gt;HospitalFilter&lt;/b&gt;&#xa;→ Filter (category)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1545" width="160" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="g-hashtag" value="&lt;b&gt;HospitalHashtag&lt;/b&gt;&#xa;tag (max 10자, 최대 5개)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1596" width="170" height="36" as="geometry"/>
