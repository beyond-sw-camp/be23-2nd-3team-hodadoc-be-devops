          <mxGeometry x="20" y="1490" width="200" height="64" as="geometry"/>
        </mxCell>
        <mxCell id="g-time" value="&lt;b&gt;HospitalOperatingTime&lt;/b&gt;&#xa;dayOfWeek (월~일)&#xa;openTime, closeTime&#xa;breakStartTime, breakEndTime&#xa;isDayOff" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
