        <mxCell id="secA-title" value="A. 병원 검색 흐름" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="130" width="250" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 1: 사용자 위치 -->
        <mxCell id="a1" value="① 사용자 위치 감지&#xa;navigator.geolocation&#xa;(거부 시 서울시청 기본값)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
