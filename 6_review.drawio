        <mxCell id="d-admin-list" value="GET /reviewreports/reviews&#xa;신고된 리뷰 목록 조회&#xa;(reportCount DESC 정렬)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="1300" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- 분기: 승인/반려 -->
        <mxCell id="d-diamond" value="관리자&#xa;판단" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="1380" width="100" height="70" as="geometry"/>
        </mxCell>

        <!-- 승인 (삭제) -->
        <mxCell id="d-approve" value="&lt;b&gt;승인 (삭제)&lt;/b&gt;&#xa;POST /{reviewId}/delete&#xa;status = DELETED&#xa;Redis 캐시 갱신" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="810" y="1370" width="170" height="64" as="geometry"/>
        </mxCell>

        <!-- 반려 (복구) -->
        <mxCell id="d-reject" value="&lt;b&gt;반려 (복구)&lt;/b&gt;&#xa;POST /{reviewId}/reject&#xa;status = NORMAL&#xa;reportCount = 0&#xa;신고 기록 삭제" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="810" y="1460" width="170" height="74" as="geometry"/>
        </mxCell>

        <!-- Section D 화살표 -->
        <mxCell id="da1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d1" target="d2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="da2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d1" target="d3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="da3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d3" target="d4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="da4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d-admin-list" target="d-diamond" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="da5" value="승인" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d-diamond" target="d-approve" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="da6" value="반려" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="d-diamond" target="d-reject" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- Section E: Redis 캐시 구조 상세                                      -->
        <!-- ================================================================== -->
        <mxCell id="secE-title" value="E. Redis 별점 캐시 구조 (Cache-Aside 패턴)" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="1560" width="400" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="e-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="1600" width="500" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="e-title2" value="&lt;b&gt;Redis DB 3&lt;/b&gt;" style="text;html=1;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="1605" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="e-key" value="Key: review:rating:{hospitalId}&#xa;Type: Hash" style="text;html=1;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="1630" width="220" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="e-fields" value="Fields:&#xa;  sum  → 전체 별점 합계 (Long)&#xa;  count → 전체 리뷰 수 (Long)&#xa;&#xa;평균 = sum / count (소수점 1자리 반올림)" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="1660" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- 갱신 시점 -->
        <mxCell id="e-timing" value="&lt;b&gt;캐시 갱신 시점&lt;/b&gt;&#xa;• 리뷰 생성: sum += rating, count += 1&#xa;• 리뷰 삭제: sum -= rating, count -= 1&#xa;• 리뷰 수정: sum += (new - old)&#xa;• 캐시 미스: DB에서 재계산 후 저장&#xa;• TTL 없음 (영구 캐시)" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="560" y="1600" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- Section F: 엔티티 관계                                               -->
        <!-- ================================================================== -->
        <mxCell id="secF-title" value="F. 엔티티 관계" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="1770" width="200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="f-review" value="&lt;b&gt;Review&lt;/b&gt;&#xa;id, contents (max 255)&#xa;rating (1~5)&#xa;status (NORMAL/REPORTED/DELETED)&#xa;reportCount" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="1810" width="210" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="f-hospital" value="&lt;b&gt;Hospital&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="1810" width="110" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="f-patient" value="&lt;b&gt;Patient&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="1860" width="110" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="f-reservation" value="&lt;b&gt;ReservationPatient&lt;/b&gt;&#xa;(Optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1910" width="150" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="f-checkin" value="&lt;b&gt;Checkin&lt;/b&gt;&#xa;(Optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1960" width="150" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="f-report" value="&lt;b&gt;ReviewReport&lt;/b&gt;&#xa;id, reason (Enum)&#xa;reporter (Account FK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="550" y="1810" width="170" height="54" as="geometry"/>
        </mxCell>
        <mxCell id="f-badword" value="&lt;b&gt;BadWord&lt;/b&gt;&#xa;word (String)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="550" y="1880" width="130" height="36" as="geometry"/>
        </mxCell>

        <!-- 관계선 -->
        <mxCell id="fa1" value="N:1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f-review" target="f-hospital" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="fa2" value="N:1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f-review" target="f-patient" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="fa3" value="N:1" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="f-review" target="f-reservation" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="fa4" value="N:1" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="f-review" target="f-checkin" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="fa5" value="1:N" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f-review" target="f-report" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================== -->
        <!-- 핵심 포인트                                                          -->
        <!-- ================================================================== -->
        <mxCell id="key-title" value="핵심 포인트" style="text;html=1;fontSize=14;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="560" y="1560" width="200" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="key-box2" value="• 리뷰 작성 조건: 예약/접수 COMPLETED + 중복 방지 (1건/1예약)&#xa;• 별점 캐싱: Redis DB 3 (Hash, sum/count), Cache-Aside 패턴&#xa;• 비속어 필터: BadWord 엔티티 기반 * 마스킹&#xa;• 소프트 삭제: status=DELETED (DB 잔존, 목록 제외)&#xa;• 신고 시스템: 중복 방지, 관리자 승인/반려 프로세스&#xa;• 비로그인 사용자: 리뷰 영역 블러 처리 + 로그인 유도 오버레이&#xa;• 권한: 작성=PATIENT, 삭제=본인+ADMIN, 신고=PATIENT+HOSPITAL_ADMIN" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="20" y="2020" width="460" height="120" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>