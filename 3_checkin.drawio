        </mxCell>
        <mxCell id="p5-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#d6b656;align=center;" value="Redis INCR (atomic)&#xa;key: checkin:waitingNumber&#xa;:{hospitalId}:{today}" vertex="1">
