        </mxCell>
        <mxCell id="ha1b" edge="1" parent="1" source="h1" target="h3" style="rounded=1;orthogonalLoop=1;strokeColor=#82b366;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ha1c" edge="1" parent="1" source="h1" target="h4" style="rounded=1;orthogonalLoop=1;strokeColor=#b85450;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ha2s" edge="1" parent="1" source="h2" target="h2-sse" style="rounded=1;orthogonalLoop=1;strokeColor=#CC6600;strokeWidth=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ha2q" edge="1" parent="1" source="h2" target="h2-queue" style="rounded=1;orthogonalLoop=1;strokeColor=#CC6600;strokeWidth=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========================================== -->
        <!-- 프론트 접수 가용성 & 알림 요약                 -->
        <!-- ========================================== -->
        <mxCell id="bottom-section" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;strokeWidth=2;dashed=1;fontSize=14;fontStyle=1;fontColor=#9673a6;verticalAlign=top;spacingTop=5;" value="접수 가용성 판단 &amp; SSE 알림 요약" vertex="1">
          <mxGeometry x="30" y="700" width="1540" height="190" as="geometry" />
        </mxCell>

        <!-- 프론트 버튼 비활성화 조건 -->
        <mxCell id="fe-disable" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=15;" value="&lt;b&gt;프론트: 접수 버튼 비활성화 조건&lt;/b&gt;&#xa;&#xa;isCheckinClosed = true → &quot;접수 마감&quot;&#xa;todayIsHoliday = true → &quot;오늘 휴무&quot;&#xa;isTodayDayOff = true → &quot;오늘 휴무&quot;&#xa;isOutsideHours = true → 버튼 비활성화&#xa;isNearClosing = true → 버튼 비활성화&#xa;&#xa;HospitalDetailSidebar.vue&#xa;checkinDisabled / checkinLabel computed" vertex="1">
          <mxGeometry x="50" y="740" width="340" height="130" as="geometry" />
        </mxCell>

        <!-- 대기번호 발급 로직 -->
        <mxCell id="waiting-logic" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=15;" value="&lt;b&gt;대기번호 발급 (Redis)&lt;/b&gt;&#xa;&#xa;Key: checkin:waitingNumber:{hospitalId}:{today}&#xa;Operation: INCR (atomic increment)&#xa;&#xa;Redis 키 없으면:&#xa;  → DB에서 오늘 최대값 조회 후 초기화&#xa;&#xa;대기순번 계산:&#xa;  WAITING 상태 중 내 번호보다 앞선 수 + 1" vertex="1">
          <mxGeometry x="430" y="740" width="340" height="130" as="geometry" />
        </mxCell>

        <!-- SSE 알림 종류 -->
        <mxCell id="sse-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#CC6600;fontSize=11;align=left;spacingLeft=15;fontColor=#333;" value="&lt;b&gt;SSE 알림 종류&lt;/b&gt;&#xa;&#xa;RECEPTION_CREATED → 병원&#xa;  (새 접수 알림)&#xa;&#xa;RECEPTION_CALLED → 환자&#xa;  (호출되었어요!)&#xa;&#xa;RECEPTION_QUEUE_UPDATE → 대기 중 전체 환자&#xa;  (대기순번 변경 시 브로드캐스트)" vertex="1">
          <mxGeometry x="810" y="740" width="300" height="130" as="geometry" />
        </mxCell>

