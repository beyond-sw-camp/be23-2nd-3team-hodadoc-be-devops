        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCC;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=10;" value="&lt;b&gt;범례&lt;/b&gt;&#xa;🔵 파란색 = 프론트엔드 (Vue)&#xa;🟢 초록색 = 백엔드 (Spring Boot)&#xa;🟡 노란색 = Redis (대기번호)&#xa;🟣 보라색 = MariaDB&#xa;🟠 주황색 = SSE 알림" vertex="1">
          <mxGeometry x="1160" y="740" width="230" height="130" as="geometry" />
        </mxCell>

