        <mxCell id="h1-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="GET /checkin/hospital&#xa;오늘 날짜 기준 전체 조회" vertex="1">
