          <mxGeometry x="280" y="440" width="130" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h2-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="PATCH /{id}/status&#xa;WAITING → CALLED" vertex="1">
          <mxGeometry x="265" y="480" width="160" height="25" as="geometry" />
        </mxCell>
        <mxCell id="h2-sse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#CC6600;fontSize=9;fontColor=#CC6600;" value="SSE → 환자: 호출되었어요!&#xa;RECEPTION_CALLED" vertex="1">
          <mxGeometry x="460" y="435" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- 대기순번 업데이트 -->
        <mxCell id="h2-queue" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#CC6600;fontSize=9;fontColor=#CC6600;" value="SSE → 대기 중인 모든 환자&#xa;RECEPTION_QUEUE_UPDATE&#xa;&quot;현재 대기 순번: N번&quot;" vertex="1">
          <mxGeometry x="460" y="485" width="200" height="45" as="geometry" />
        </mxCell>

        <!-- 진료 완료 -->
        <mxCell id="h3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" value="③ 진료 완료" vertex="1">
          <mxGeometry x="280" y="550" width="130" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h3-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#82b366;align=center;" value="PATCH /{id}/status&#xa;CALLED → COMPLETED" vertex="1">
          <mxGeometry x="265" y="590" width="160" height="25" as="geometry" />
        </mxCell>

        <!-- 접수 취소 -->
        <mxCell id="h4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" value="④ 접수 취소" vertex="1">
          <mxGeometry x="280" y="630" width="130" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h4-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#b85450;align=center;" value="WAITING → CANCELLED&#xa;+ 대기순번 재계산 브로드캐스트" vertex="1">
          <mxGeometry x="255" y="670" width="180" height="25" as="geometry" />
        </mxCell>

        <!-- 접수 마감 -->
        <mxCell id="h5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" value="⑤ 접수 수동 마감" vertex="1">
          <mxGeometry x="730" y="450" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h5-sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#b85450;align=center;" value="PATCH /hospital/{id}/checkin-close&#xa;환자 화면: 접수하기 버튼 비활성화&#xa;텍스트 → &quot;접수 마감&quot;" vertex="1">
          <mxGeometry x="700" y="500" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- 상태 전이도 -->
        <mxCell id="status-flow" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#4A86C8;fontSize=10;align=left;spacingLeft=15;" value="&lt;b&gt;접수 상태 전이&lt;/b&gt;&#xa;&#xa;WAITING → CALLED → COMPLETED&#xa;WAITING → CANCELLED&#xa;&#xa;환자 직접 취소:&#xa;  DELETE /checkin/patient/{id}&#xa;  WAITING 상태에서만 가능" vertex="1">
          <mxGeometry x="730" y="560" width="250" height="110" as="geometry" />
        </mxCell>

        <!-- 병원관리자 화살표 -->
        <mxCell id="ha1a" edge="1" parent="1" source="h1" target="h2" style="rounded=1;orthogonalLoop=1;strokeColor=#82b366;strokeWidth=2;">
