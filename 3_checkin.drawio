        <!-- Step 2: 접수하기 버튼 -->
        <mxCell id="p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" value="② 접수하기&#xa;버튼 클릭" vertex="1">
