        <!-- 가용성 검증 상세 -->
        <mxCell id="p4-validate" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;fontSize=9;align=left;spacingLeft=10;" value="&lt;b&gt;가용성 검증 (Backend)&lt;/b&gt;&#xa;&#xa;1. 병원 삭제 여부 체크&#xa;2. 관리자 수동 마감 여부 체크&#xa;3. 병원 휴무일 (HospitalHoliday) 체크&#xa;4. 공휴일 (PublicHoliday) 체크&#xa;5. 운영시간 외 여부 체크&#xa;6. 마감 30분 전 여부 체크&#xa;7. 오늘 중복 접수 체크" vertex="1">
          <mxGeometry x="440" y="230" width="260" height="140" as="geometry" />
        </mxCell>

